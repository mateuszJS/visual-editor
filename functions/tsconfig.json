{
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["@cloudflare/vitest-pool-workers"],
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./env.d.ts",
    "./handlers.d.ts",
    "./types.d.ts",
    "../vitest.config.mts",
    "../src/utils/getUserAgent.ts",
    "../apiTypes.ts"
  ]
}
